# Secret Configuration Template
# Copy this file to application-secret.properties and fill in your actual values
# DO NOT commit application-secret.properties to Git

# OpenAI API Key
# Get your API key from: https://platform.openai.com/api-keys
openai.api-key=sk-proj-YOUR_OPENAI_API_KEY_HERE

# OAuth2 Client Secrets
# Kakao: https://developers.kakao.com/
spring.security.oauth2.client.registration.kakao.client-secret=YOUR_KAKAO_CLIENT_SECRET

# Google: https://console.cloud.google.com/
# spring.security.oauth2.client.registration.google.client-secret=YOUR_GOOGLE_CLIENT_SECRET

# Naver: https://developers.naver.com/
# spring.security.oauth2.client.registration.naver.client-secret=YOUR_NAVER_CLIENT_SECRET

# Database Password
spring.datasource.password=YOUR_DB_PASSWORD